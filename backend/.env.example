# Backend Environment Variables
APP_NAME=KnowledgeFlow AI
APP_VERSION=1.0.0
DEBUG=True

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/knowledgeflow

# Storage
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./storage

# AI
GEMINI_API_KEY=your_gemini_api_key_here

# Clerk
CLERK_SECRET_KEY=sk_your_clerk_secret_key
CLERK_PUBLISHABLE_KEY=pk_your_clerk_publishable_key
CLERK_JWT_ISSUER=https://your-clerk-subdomain.clerk.accounts.dev
